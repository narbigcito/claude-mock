<!DOCTYPE html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{@conversation.title}</title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/base16/atelier-forest.min.css"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js">
    </script>
    <style>
      html, body { background: transparent; }
      body { padding: 0; margin: 0; }
    </style>
  </head>
  <body class="bg-claude-bg text-claude-text antialiased">
    <div class="mx-auto w-full max-w-3xl space-y-6 px-4 py-6">
      <ChatComponents.message :for={m <- @conversation.messages} message={m} />
    </div>
    <script>
      document.querySelectorAll('pre code').forEach((el) => window.hljs && window.hljs.highlightElement(el));
    </script>
  </body>
</html>
