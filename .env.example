# Copy to `.env` and fill in values.
# Generate a secret key base with: `mix phx.gen.secret` (64+ chars).
SECRET_KEY_BASE=change-me-run-mix-phx-gen-secret

# DB credentials used by both `db` and `app` services.
POSTGRES_USER=claude_mock
POSTGRES_PASSWORD=claude_mock
POSTGRES_DB=claude_mock_prod

# Host the Phoenix endpoint will advertise.
PHX_HOST=localhost

# If true, the `app` container runs the conversation importer on every boot.
# Safe — existing titles are skipped.
SEED_ON_BOOT=true

# OpenAI-compatible LLM provider used by the admin "Desde imagen" flow.
# Leave PANOPTIKON_API_KEY blank if you don't use that feature.
PANOPTIKON_BASE_URL=https://panoptikon.narbigcito.com/v1
PANOPTIKON_API_KEY=
PANOPTIKON_MODEL=kimi-k2-turbo-preview
